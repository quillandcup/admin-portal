# ==============================================================================
# Environment Configuration Template
# ==============================================================================
# Copy this file to .env.local and fill in your development credentials
#
# IMPORTANT:
# - .env.local is gitignored and used for local development only
# - Production/Preview environments use Vercel environment variables
# - Never commit secrets to git
# - See docs/DEPLOYMENT_SETUP.md for full setup guide
# ==============================================================================

# ------------------------------------------------------------------------------
# Supabase Configuration (DEVELOPMENT)
# ------------------------------------------------------------------------------
# Get these from your DEVELOPMENT Supabase project
# Dashboard → Settings → API
# Production uses different credentials set in Vercel dashboard

NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional: Service role key for admin operations (keep secret!)
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ------------------------------------------------------------------------------
# Zoom API Credentials
# ------------------------------------------------------------------------------
# Create app at: https://marketplace.zoom.us/develop/create
# Use development/test credentials here

ZOOM_ACCOUNT_ID=your_zoom_account_id
ZOOM_CLIENT_ID=your_zoom_client_id
ZOOM_CLIENT_SECRET=your_zoom_client_secret

# ------------------------------------------------------------------------------
# Google Calendar Integration
# ------------------------------------------------------------------------------
# Service account key from Google Cloud Console
# https://console.cloud.google.com/iam-admin/serviceaccounts
# Use development calendar for testing

GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"..."}
GOOGLE_CALENDAR_ID=your_dev_calendar_id@group.calendar.google.com

# ------------------------------------------------------------------------------
# Kajabi Integration
# ------------------------------------------------------------------------------
# OAuth credentials for Kajabi API access
# Get from Kajabi: Settings → Integrations → API
# Site ID: Find in your Kajabi admin URL (e.g., /admin/sites/2147577478)

KAJABI_CLIENT_ID=your_kajabi_client_id
KAJABI_CLIENT_SECRET=your_kajabi_client_secret
KAJABI_SITE_ID=your_kajabi_site_id

# ------------------------------------------------------------------------------
# Slack Integration
# ------------------------------------------------------------------------------
# Create Slack app at: https://api.slack.com/apps
# Get bot token from OAuth & Permissions section
# Required scopes: channels:history, channels:read, users:read, reactions:read

SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# ------------------------------------------------------------------------------
# Stripe Integration
# ------------------------------------------------------------------------------
# Get API key from Stripe Dashboard: Developers → API keys
# Use test mode for development, live mode for production
# Format: sk_test_... (development) or sk_live_... (production)

STRIPE_API_KEY=sk_test_your_stripe_api_key

# ------------------------------------------------------------------------------
# Webhook Security (PRODUCTION ONLY - Set in Vercel)
# ------------------------------------------------------------------------------
# ⚠️  IMPORTANT: These are production secrets
# Set these ONLY in Vercel environment variables, NEVER in .env.local
# Vercel Dashboard → Settings → Environment Variables → Production
#
# Secret tokens for verifying webhook signatures
# These ensure webhooks are from the claimed source

# Zoom Webhook Secret Token (from Zoom webhook settings)
# ZOOM_WEBHOOK_SECRET_TOKEN=your_zoom_webhook_secret

# Slack Signing Secret (from Slack app settings)
# SLACK_SIGNING_SECRET=your_slack_signing_secret

# Google Calendar uses channel tokens (set when creating watch)
# Generate with: openssl rand -hex 32
# GOOGLE_CALENDAR_WEBHOOK_TOKEN=your_google_webhook_token

# ------------------------------------------------------------------------------
# Vercel Cron Jobs (Production only)
# ------------------------------------------------------------------------------
# Secret for authenticating cron job requests
# Generate with: openssl rand -hex 32
# Only needed in production; optional for testing locally

# CRON_SECRET=your_generated_secret_here

# ==============================================================================
# Quick Setup
# ==============================================================================
# Option 1: Pull from Vercel (recommended)
#   vercel env pull .env.local --environment=development
#
# Option 2: Use setup script
#   ./scripts/setup-environments.sh
#
# Option 3: Manual setup
#   Copy this file to .env.local and fill in values manually
# ==============================================================================
